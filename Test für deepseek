-- ===== SKIN CHANGER (ERWEITERT) =====
-- Hilfsfunktion: Spieler über Roblox-API suchen (auch außerhalb des Spiels)
local function FetchPlayerFromAPI(username)
    local success, result = pcall(function()
        return game:HttpGet("https://users.roblox.com/v1/users/search?keyword=" .. username .. "&limit=1")
    end)
    if not success then return nil end
    local data = game:GetService("HttpService"):JSONDecode(result)
    if data and data.data and #data.data > 0 then
        return data.data[1].id
    end
    return nil
end

-- Hilfsfunktion: Skin-Daten eines Spielers von der API abrufen
local function FetchSkinFromAPI(userId)
    local success, result = pcall(function()
        return game:HttpGet("https://avatar.roblox.com/v1/users/" .. userId .. "/avatar")
    end)
    if not success then return nil end
    local data = game:GetService("HttpService"):JSONDecode(result)
    return data
end

local function CopySkin(targetUsername)
    local targetPlayer = nil
    local targetUserId = nil

    -- 1. Zuerst im Spiel suchen
    for _, player in pairs(Players:GetPlayers()) do
        if string.lower(player.Name) == string.lower(targetUsername) then
            targetPlayer = player
            break
        end
    end

    -- 2. Falls nicht im Spiel, über API suchen
    if not targetPlayer then
        targetUserId = FetchPlayerFromAPI(targetUsername)
        if not targetUserId then
            WindUI:Notify({Title = "Skin Changer", Content = "Spieler nicht gefunden!", Duration = 3})
            return
        end
    end

    local localChar = LocalPlayer.Character
    if not localChar then
        WindUI:Notify({Title = "Skin Changer", Content = "Dein Charakter existiert nicht!", Duration = 3})
        return
    end

    -- 3. Vorhandene Kleidung & Accessoires löschen
    for _, child in pairs(localChar:GetChildren()) do
        if child:IsA("Accessory") or child:IsA("Shirt") or child:IsA("Pants") or child:IsA("ShirtGraphic") or child:IsA("Hat") or child:IsA("Hair") then
            child:Destroy()
        end
    end

    -- 4. Skin vom Ziel kopieren
    if targetPlayer then
        -- Spieler ist im Spiel → direkt vom Character kopieren
        local targetChar = targetPlayer.Character
        if not targetChar then
            WindUI:Notify({Title = "Skin Changer", Content = "Ziel-Charakter nicht gefunden!", Duration = 3})
            return
        end

        -- Accessoires kopieren
        for _, child in pairs(targetChar:GetChildren()) do
            if child:IsA("Accessory") then
                local newAccessory = child:Clone()
                newAccessory.Parent = localChar
                if newAccessory:FindFirstChild("Handle") then
                    newAccessory.Handle:BreakJoints()
                end
                task.wait(0.05)
            end
        end

        -- Kleidung kopieren
        local shirt = targetChar:FindFirstChild("Shirt")
        local pants = targetChar:FindFirstChild("Pants")
        local shirtGraphic = targetChar:FindFirstChild("ShirtGraphic")
        if shirt then shirt:Clone().Parent = localChar end
        if pants then pants:Clone().Parent = localChar end
        if shirtGraphic then shirtGraphic:Clone().Parent = localChar end

        -- Haare kopieren (Accessoires, die als Hair getaggt sind)
        for _, child in pairs(targetChar:GetChildren()) do
            if child:IsA("Accessory") and child:FindFirstChild("Handle") and child.Handle:FindFirstChild("Hair") then
                local newHair = child:Clone()
                newHair.Parent = localChar
                if newHair:FindFirstChild("Handle") then
                    newHair.Handle:BreakJoints()
                end
                task.wait(0.05)
            end
        end

        WindUI:Notify({Title = "Skin Changer", Content = "Skin von " .. targetUsername .. " kopiert!", Duration = 3})

    elseif targetUserId then
        -- Spieler nicht im Spiel → Skin über API laden
        local avatarData = FetchSkinFromAPI(targetUserId)
        if not avatarData or not avatarData.assets then
            WindUI:Notify({Title = "Skin Changer", Content = "Skin-Daten konnten nicht geladen werden!", Duration = 3})
            return
        end

        -- Accessoires aus API-Daten laden
        for _, asset in pairs(avatarData.assets) do
            if asset.assetTypeId == 41 then -- Hair
                local hair = Instance.new("Accessory")
                hair.Name = "Hair"
                hair.Handle = Instance.new("Part")
                hair.Handle.Name = "Handle"
                hair.Handle.Transparency = 1
                hair.Handle.Anchored = true
                hair.Handle.CanCollide = false
                hair.Handle.Size = Vector3.new(1, 1, 1)
                hair.TextureID = asset.assetId
                hair.Parent = localChar
                task.wait(0.05)
            elseif asset.assetTypeId == 8 then -- Hat / Accessory
                local accessory = Instance.new("Accessory")
                accessory.Name = "Accessory"
                accessory.Handle = Instance.new("Part")
                accessory.Handle.Name = "Handle"
                accessory.Handle.Transparency = 1
                accessory.Handle.Anchored = true
