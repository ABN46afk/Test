local function UpdateTeamList()
    -- Vorhandene Buttons entfernen (einfach: Section leeren – hier als Platzhalter)
    -- In WindUI gibt es keine direkte Methode zum Leeren einer Section.
    -- Stattdessen erstellen wir die Liste bei jedem Aufruf neu.
    -- (Für eine saubere Lösung müsste man die Section-Elemente manuell verwalten.)
    -- Wir nutzen hier eine einfache Notiz: Die Liste wird im UI dynamisch aktualisiert.
    -- Da WindUI keine dynamische Listenaktualisierung bietet, zeigen wir die Spieler als Buttons an.
    -- Wir verwenden eine separate Section für die Liste.
end

-- Da WindUI keine dynamische Liste unterstützt, erstellen wir eine Section mit Buttons für jeden Spieler.
-- Diese wird bei jedem Tab-Wechsel oder per Button neu aufgebaut.
local function RefreshNearbyPlayers()
    -- Alte Liste entfernen (falls vorhanden)
    local oldList = TeamTab:FindFirstChild("NearbyPlayersList")
    if oldList then
        oldList:Destroy()
    end

    local listSection = TeamTab:Section({Title = "NearbyPlayersList", Visible = false})
    listSection.Name = "NearbyPlayersList"
    local nearby = GetNearbyPlayers()
    if #nearby == 0 then
        local emptyLabel = listSection:Label({Text = "Keine Spieler in der Nähe."})
    else
        for _, player in pairs(nearby) do
            local btn = listSection:Button({
                Text = player.Name .. " (hinzufügen)",
                Callback = function()
                    local alreadyInTeam = false
                    for _, teamPlayer in pairs(CustomTeamPlayers) do
                        if teamPlayer == player then
                            alreadyInTeam = true
                            break
                        end
                    end
                    if not alreadyInTeam then
                        table.insert(CustomTeamPlayers, player)
                        WindUI:Notify({Title = "Team", Content = player.Name .. " zum Team hinzugefügt!", Duration = 2})
                    else
                        WindUI:Notify({Title = "Team", Content = player.Name .. " ist bereits im Team!", Duration = 2})
                    end
                end
            })
        end
    end
end

