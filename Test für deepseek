local function ApplyGhostEffect(effectType)
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Cleanup old effects
    for _, effect in pairs(ghostEffects) do
        pcall(function() effect:Destroy() end)
    end
    ghostEffects = {}
    if ghostHighlight then
        pcall(function() ghostHighlight:Destroy() end)
        ghostHighlight = nil
    end

    if effectType == "None" then
        return
    end

    -- Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = "GhostHighlight"
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.FillTransparency = 0.3
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Parent = character
    ghostHighlight = highlight

    -- Connector for color changes
    local conn
    if effectType == "Rainbow" then
        conn = RunService.RenderStepped:Connect(function()
            if highlight then
                local hue = (tick() * 0.2) % 1
                highlight.FillColor = Color3.fromHSV(hue, 1, 1)
            end
        end)
        table.insert(ghostConnections, conn)
    end

    -- Attachments
    local top = Instance.new("Attachment", hrp)
    top.Position = Vector3.new(0, 1.5, 0)
    table.insert(ghostEffects, top)
    local bottom = Instance.new("Attachment", hrp)
    bottom.Position = Vector3.new(0, -1.5, 0)
