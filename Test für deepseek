-- ===== AIMBOT =====
local function GetTargets()
    local Targets = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 and IsEnemy(player) then
            local Part = player.Character:FindFirstChild(TargetPart)
            if not Part then
                Part = player.Character:FindFirstChild("HumanoidRootPart")
            end
            if Part then
                local Distance = (Part.Position - Camera.CFrame.Position).Magnitude
                if Distance <= FOV * 3 then
                    table.insert(Targets, {Part = Part, Distance = Distance, Player = player})
                end
            end
        end
    end
    table.sort(Targets, function(a, b) return a.Distance < b.Distance end)
    return Targets
end

-- ===== AIM-FUNKTION =====
local function AimAtTargets(Targets)
    if #Targets == 0 then return end
    local avgPos = Vector3.new(0, 0, 0)
    local validTargets = 0
    local count = math.min(#Targets, MaxTargets)
    for i = 1, count do
        local target = Targets[i]
        if target and target.Part and IsVisible(target.Part) then
            avgPos = avgPos + target.Part.Position
            validTargets = validTargets + 1
        end
    end
    if validTargets == 0 then return end
    avgPos = avgPos / validTargets

    if PredictionEnabled then
        local vel = Vector3.new(0, 0, 0)
        local velCount = 0
        for i = 1, count do
            local root = Targets[i].Part.Parent and Targets[i].Part.Parent:FindFirstChild("HumanoidRootPart")
            if root then
                vel = vel + root.Velocity
                velCount = velCount + 1
            end
        end
        if velCount > 0 then
            avgPos = avgPos + (vel / velCount) * PredictionAmount
        end
    end

    local currentCF = Camera.CFrame
    local targetCF = CFrame.new(currentCF.Position, avgPos)

    if AimSpeed > 0 then
        local relative = currentCF:ToObjectSpace(targetCF)
        local angles = Vector3.new(
            math.atan2(-relative.LookVector.Y, relative.LookVector.Z),
            math.atan2(relative.LookVector.X, relative.LookVector.Z),
            0
        )
        local maxAngle = math.rad(AimSpeed * 0.1)
        local clampedAngles = Vector3.new(
            math.clamp(angles.X, -maxAngle, maxAngle),
            math.clamp(angles.Y, -maxAngle, maxAngle),
            0
        )
        Camera.CFrame = currentCF * CFrame.fromEulerAnglesXYZ(clampedAngles.X, clampedAngles.Y, 0)
    else
        Camera.CFrame = targetCF
    end
end

